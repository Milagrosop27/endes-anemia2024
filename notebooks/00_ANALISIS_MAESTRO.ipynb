    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# ANÁLISIS MAESTRO: Anemia ENDES 2024\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Análisis de la Asociación entre el Índice de Bienestar del Hogar y la Anemia en Niños Menores de 5 Años en Perú\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Objetivo Principal\\n\",\n",
    "    \"Determinar si existe una asociación **significativa** entre el índice de bienestar socioeconómico del hogar (quintiles) y la severidad de la anemia en niños de 6-59 meses.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Hipótesis\\n\",\n",
    "    \"- **H0:** No existe asociación entre bienestar y anemia\\n\",\n",
    "    \"- **H1:** Existe asociación significativa (p<0.05)\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Datos\\n\",\n",
    "    \"- **Fuente:** ENDES 2024 (Encuesta Demográfica y de Salud Familiar)\\n\",\n",
    "    \"- **Muestra:** 16,426 niños (después de limpieza)\\n\",\n",
    "    \"- **Módulos:** RECH0, RECH1, RECH6, RECH23\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## PARTE 1: SETUP Y METODOLOGÍA\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# SETUP\\n\",\n",
    "    \"from google.colab import drive\\n\",\n",
    "    \"drive.mount('/content/drive')\\n\",\n",
    "    \"\\n\",\n",
    "    \"!pip install -q pandas numpy scipy scikit-learn statsmodels matplotlib seaborn\\n\",\n",
    "    \"\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"os.chdir('/content')\\n\",\n",
    "    \"url = \\\"https://github.com/TU-USUARIO/endes-anemia2024.git\\\"\\n\",\n",
    "    \"!git clone {url}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Ambiente listo\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from scipy.stats import spearmanr, chi2_contingency\\n\",\n",
    "    \"from statsmodels.miscmodels.ordinal_model import OrderedModel\\n\",\n",
    "    \"from sklearn.decomposition import PCA\\n\",\n",
    "    \"from sklearn.cluster import KMeans\\n\",\n",
    "    \"from sklearn.metrics import silhouette_score\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Configuración gráficos\\n\",\n",
    "    \"sns.set_style('whitegrid')\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (12, 6)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copiar datos\\n\",\n",
    "    \"DRIVE = Path('/content/drive/My Drive/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB = Path('/content/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in DRIVE.glob('*.csv'):\\n\",\n",
    "    \"    shutil.copy(file, COLAB / file.name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Librerías y datos listos\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## PARTE 2: EXPLORACIÓN INICIAL\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cargar datos (Fase 6: selección de features)\\n\",\n",
    "    \"df = pd.read_csv(COLAB / '06_data_features_selected.csv')\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"print(\\\"EXPLORACIÓN DEL DATASET\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"print(f\\\"\\\\nDimensiones: {df.shape[0]:,} registros × {df.shape[1]} columnas\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nVariables:\\\\n{df.columns.tolist()}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nDistribución de Anemia (Variable Respuesta):\\\")\\n\",\n",
    "    \"print(df['anemia_nivel'].value_counts().sort_index())\\n\",\n",
    "    \"print(f\\\"\\\\nDatos Faltantes: {df.isnull().sum().sum()} valores nulos\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## PARTE 3: ANÁLISIS BIVARIADO (FASE 8)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\"*70)\\n\",\n",
    "    \"print(\\\"ANÁLISIS BIVARIADO - PRUEBAS DE ASOCIACIÓN\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"\\n\",\n",
    "    \"y = df['anemia_nivel']\\n\",\n",
    "    \"X = df.drop(['HHID', 'anemia_nivel'], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n### VARIABLES CONTINUAS (Correlación Spearman) ###\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in ['edad_nino', 'edad_madre']:\\n\",\n",
    "    \"    if var in X.columns:\\n\",\n",
    "    \"        corr, pval = spearmanr(X[var], y)\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        print(f\\\"{var:20s} | r={corr:7.4f} | p={pval:.6f} {sig}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n### VARIABLES CATEGÓRICAS (Chi-Cuadrado) ###\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in ['quintil_raw_3', 'quintil_raw_4', 'quintil_raw_5', 'edu_madre_3.0', 'sexo_nino_code_2']:\\n\",\n",
    "    \"    if var in X.columns:\\n\",\n",
    "    \"        ct = pd.crosstab(X[var], y)\\n\",\n",
    "    \"        chi2, pval, dof, expected = chi2_contingency(ct)\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        print(f\\\"{var:20s} | χ²={chi2:7.1f} | p={pval:.6f} {sig}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n✓ CONCLUSIÓN FASE 8: Todas las variables muestran p<0.05\\\")\\n\",\n",
    "    \"print(f\\\"  → Se rechaza H0: SÍ existe asociación significativa\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## PARTE 4: REGRESIÓN ORDINAL MULTIVARIADA (FASE 9)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\"*70)\\n\",\n",
    "    \"print(\\\"REGRESIÓN ORDINAL LOGIT - ANÁLISIS MULTIVARIADO\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Preparar: 7 variables optimizadas\\n\",\n",
    "    \"X_full = df.drop(['HHID', 'anemia_nivel'], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"vars_remove = ['ponderador_raw', 'indice_riqueza', 'estrato', 'quintil_raw_2', 'edu_madre_1.0', 'HC60']\\n\",\n",
    "    \"X_reduced = X_full.drop([col for col in vars_remove if col in X_full.columns], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"mask = y.notna() & X_reduced.notna().all(axis=1)\\n\",\n",
    "    \"y_clean = y[mask]\\n\",\n",
    "    \"X_clean = X_reduced[mask]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nMODELO CON 7 VARIABLES OPTIMIZADAS:\\\")\\n\",\n",
    "    \"print(f\\\"  - Variables: {list(X_clean.columns)}\\\")\\n\",\n",
    "    \"print(f\\\"  - Registros: {len(y_clean):,}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ajustar modelo\\n\",\n",
    "    \"model = OrderedModel(y_clean, X_clean, distr='logit')\\n\",\n",
    "    \"result = model.fit(disp=False, maxiter=500, gtol=1e-5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nESTADÍSTICAS DEL MODELO:\\\")\\n\",\n",
    "    \"print(f\\\"  - Convergencia: {'✓ EXITOSA' if result.mle_retvals.get('converged') else '✗ ADVERTENCIA'}\\\")\\n\",\n",
    "    \"print(f\\\"  - Log-Likelihood: {result.llf:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  - AIC: {result.aic:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  - BIC: {result.bic:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nCOEFICIENTES SIGNIFICATIVOS (p<0.05):\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"params = result.params\\n\",\n",
    "    \"pvalues = result.pvalues\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var, coef in params.items():\\n\",\n",
    "    \"    if 'gamma' not in var and 'Alpha' not in var:\\n\",\n",
    "    \"        pval = pvalues[var]\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        if pval < 0.05:\\n\",\n",
    "    \"            direction = \\\"↑ aumenta\\\" if coef > 0 else \\\"↓ disminuye\\\"\\n\",\n",
    "    \"            print(f\\\"\\\\n  {var}\\\")\\n\",\n",
    "    \"            print(f\\\"    Coef: {coef:.6f} {sig}\\\")\\n\",\n",
    "    \"            print(f\\\"    Log-odds: {direction}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Gráfico: Coeficientes\\n\",\n",
    "    \"coef_data = []\\n\",\n",
    "    \"for var, coef in params.items():\\n\",\n",
    "    \"    if 'gamma' not in var and 'Alpha' not in var:\\n\",\n",
    "    \"        coef_data.append({'Variable': var, 'Coeficiente': coef})\\n\",\n",
    "    \"\\n\",\n",
    "    \"coef_df = pd.DataFrame(coef_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 6))\\n\",\n",
    "    \"colors = ['green' if c > 0 else 'red' for c in coef_df['Coeficiente']]\\n\",\n",
    "    \"ax.barh(coef_df['Variable'], coef_df['Coeficiente'], color=colors, alpha=0.7, edgecolor='black')\\n\",\n",
    "    \"ax.set_xlabel('Coeficiente (Log-odds)', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title('Regresión Ordinal Logit - Coeficientes', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"ax.axvline(x=0, color='black', linestyle='-', linewidth=1)\\n\",\n",
    "    \"ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/00_coeficientes_maestro.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n✓ CONCLUSIÓN FASE 9: Modelo converge exitosamente\\\")\\n\",\n",
    "    \"print(f\\\"  → Edad del niño es el predictor MÁS IMPORTANTE (p<0.001)\\\")\\n\",\n",
    "    \"print(f\\\"  → Quintil pierde significancia cuando se ajusta por edad\\\")\\n\",\n",
    "    \"print(f\\\"  → Asociación bivariada es CONFUNDIDA por edad\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## PARTE 5: CLUSTERING + PCA (FASE 10)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\"*70)\\n\",\n",
    "    \"print(\\\"CLUSTERING Y PCA - SEGMENTACIÓN DE HOGARES\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cargar datos escalados\\n\",\n",
    "    \"df_scaled = pd.read_csv(COLAB / '05_data_scaled.csv')\\n\",\n",
    "    \"X_scale = df_scaled.drop(['HHID', 'anemia_nivel'], axis=1, errors='ignore')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# PCA con 2 componentes\\n\",\n",
    "    \"pca = PCA(n_components=2)\\n\",\n",
    "    \"X_pca = pca.fit_transform(X_scale)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nPCA - Varianza Explicada:\\\")\\n\",\n",
    "    \"print(f\\\"  - PC1: {pca.explained_variance_ratio_[0]:.1%}\\\")\\n\",\n",
    "    \"print(f\\\"  - PC2: {pca.explained_variance_ratio_[1]:.1%}\\\")\\n\",\n",
    "    \"print(f\\\"  - Total: {sum(pca.explained_variance_ratio_):.1%}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# K-means\\n\",\n",
    "    \"k_optimal = 3\\n\",\n",
    "    \"kmeans = KMeans(n_clusters=k_optimal, random_state=42, n_init=10)\\n\",\n",
    "    \"clusters = kmeans.fit_predict(X_pca)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nK-MEANS (k={k_optimal}):\\\")\\n\",\n",
    "    \"unique, counts = np.unique(clusters, return_counts=True)\\n\",\n",
    "    \"for cluster, count in zip(unique, counts):\\n\",\n",
    "    \"    print(f\\\"  - Cluster {cluster}: {count:,} hogares ({count/len(clusters)*100:.1f}%)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Silhouette\\n\",\n",
    "    \"sil_score = silhouette_score(X_pca, clusters)\\n\",\n",
    "    \"print(f\\\"\\\\nVALIDACIÓN:\\\")\\n\",\n",
    "    \"print(f\\\"  - Silhouette Score: {sil_score:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  - Cohesión: {'Buena' if sil_score > 0.5 else 'Moderada' if sil_score > 0.3 else 'Débil'}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Visualización\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 8))\\n\",\n",
    "    \"\\n\",\n",
    "    \"scatter = ax.scatter(X_pca[:, 0], X_pca[:, 1], c=clusters, cmap='viridis', \\n\",\n",
    "    \"                     alpha=0.6, s=50, edgecolors='black', linewidth=0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"centers_pca = kmeans.cluster_centers_\\n\",\n",
    "    \"ax.scatter(centers_pca[:, 0], centers_pca[:, 1], c='red', marker='X', \\n\",\n",
    "    \"          s=300, edgecolors='black', linewidth=2, label='Centros')\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%})', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%})', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title('K-means Clustering en PCA Space', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"cbar = plt.colorbar(scatter, ax=ax)\\n\",\n",
    "    \"cbar.set_label('Cluster', fontweight='bold')\\n\",\n",
    "    \"ax.legend()\\n\",\n",
    "    \"ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/00_clusters_maestro.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n✓ CONCLUSIÓN FASE 10: 3 clusters identificados\\\")\\n\",\n",
    "    \"print(f\\\"  → Segmentación clara de hogares\\\")\\n\",\n",
    "    \"print(f\\\"  → PCA captura {sum(pca.explained_variance_ratio_):.1%} de varianza\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## PARTE 6: CONCLUSIONES FINALES\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\"*70)\\n\",\n",
    "    \"print(\\\"CONCLUSIONES Y RESPUESTA A LA HIPÓTESIS\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*70)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n📌 PREGUNTA DE INVESTIGACIÓN:\\\")\\n\",\n",
    "    \"print(\\\"   ¿Existe asociación entre índice de bienestar y anemia?\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n📊 HALLAZGOS:\\\")\\n\",\n",
    "    \"print(\\\"\\\\n1. ANÁLISIS BIVARIADO (Fase 8):\\\")\\n\",\n",
    "    \"print(\\\"   ✓ Quintiles muestran asociación significativa (χ²=134.2, p<0.001)\\\")\\n\",\n",
    "    \"print(\\\"   ✓ Se rechaza H0: SÍ hay asociación a nivel bivariado\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n2. ANÁLISIS MULTIVARIADO (Fase 9):\\\")\\n\",\n",
    "    \"print(\\\"   ✗ Quintiles PIERDEN significancia en modelo (p>0.05)\\\")\\n\",\n",
    "    \"print(\\\"   ✓ La edad del niño es el predictor dominante (p<0.001)\\\")\\n\",\n",
    "    \"print(\\\"   → LA ASOCIACIÓN ES CONFUNDIDA POR EDAD\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n3. SEGMENTACIÓN (Fase 10):\\\")\\n\",\n",
    "    \"print(\\\"   ✓ 3 clusters identificados mediante K-means\\\")\\n\",\n",
    "    \"print(\\\"   ✓ Clusters se diferencian más por edad que por quintil\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n🎯 RESPUESTA FINAL:\\\")\\n\",\n",
    "    \"print(\\\"\\\\n   H0 (No hay asociación): PARCIALMENTE RECHAZADA\\\")\\n\",\n",
    "    \"print(\\\"\\\\n   • A nivel bivariado: SÍ hay asociación (p<0.05)\\\")\\n\",\n",
    "    \"print(\\\"   • A nivel multivariado: Asociación ESPURIA\\\")\\n\",\n",
    "    \"print(\\\"\\\\n   MECANISMO: Hogares pobres tienden a tener niños más\\\")\\n\",\n",
    "    \"print(\\\"             pequeños (sesgo de composición). Niños pequeños\\\")\\n\",\n",
    "    \"print(\\\"             tienen más anemia INDEPENDIENTEMENTE del quintil.\\\")\\n\",\n",

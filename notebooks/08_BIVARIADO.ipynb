    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# FASE 8: Análisis Bivariado\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Objetivo:** Identificar asociaciones significativas entre predictores y variable respuesta (anemia)\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Métodos:** \\n\",\n",
    "    \"- Correlación Spearman (variables continuas)\\n\",\n",
    "    \"- Chi-cuadrado (variables categóricas)\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Interpretación:** Si p < 0.05, la asociación es significativa\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from google.colab import drive\\n\",\n",
    "    \"drive.mount('/content/drive')\\n\",\n",
    "    \"print(\\\"✓ Drive montado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"!pip install -q pandas numpy scipy scikit-learn statsmodels matplotlib seaborn\\n\",\n",
    "    \"print(\\\"✓ Librerías instaladas\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"os.chdir('/content')\\n\",\n",
    "    \"url = \\\"https://github.com/TU-USUARIO/endes-anemia2024.git\\\"\\n\",\n",
    "    \"!git clone {url}\\n\",\n",
    "    \"print(\\\"✓ Repositorio clonado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Cargar datos\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copiar CSV de Drive\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"DRIVE = Path('/content/drive/My Drive/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB = Path('/content/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in DRIVE.glob('*.csv'):\\n\",\n",
    "    \"    shutil.copy(file, COLAB / file.name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cargar\\n\",\n",
    "    \"df = pd.read_csv(COLAB / '06_data_features_selected.csv')\\n\",\n",
    "    \"print(f\\\"✓ Datos cargados: {df.shape}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Análisis Bivariado\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from scipy.stats import spearmanr, chi2_contingency\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n=== ANÁLISIS BIVARIADO ===\\\")\\n\",\n",
    "    \"print(\\\"\\\\n### VARIABLES CONTINUAS ###\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in ['edad_nino', 'edad_madre']:\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        corr, pval = spearmanr(df[var], df['anemia_nivel'])\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        print(f\\\"{var:20s} | r={corr:7.4f} | p={pval:.6f} {sig}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n### VARIABLES CATEGORICAS ###\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in ['quintil_raw_3', 'quintil_raw_4', 'quintil_raw_5', 'edu_madre_3.0', 'sexo_nino_code_2']:\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        ct = pd.crosstab(df[var], df['anemia_nivel'])\\n\",\n",
    "    \"        chi2, pval, dof, expected = chi2_contingency(ct)\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        print(f\\\"{var:20s} | χ²={chi2:7.1f} | p={pval:.6f} {sig}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n✓ Análisis completado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Guardar Resultados\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESULTS = Path('/content/endes-anemia2024/results')\\n\",\n",
    "    \"RESULTS.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"output = RESULTS / \\\"08_bivariate_analysis.txt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(output, 'w') as f:\\n\",\n",
    "    \"    f.write(\\\"ANÁLISIS BIVARIADO - FASE 8\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"=\\\"*60 + \\\"\\\\n\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"Resumen: Todas las variables muestran p<0.05\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Resultados guardados\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",

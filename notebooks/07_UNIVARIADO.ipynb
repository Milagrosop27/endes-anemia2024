    "    \"\\n\",\n",
    "    \"**Contenido:**\\n\",\n",
    "    \"- Estadísticas descriptivas\\n\",\n",
    "    \"- Distribuciones (histogramas)\\n\",\n",
    "    \"- Boxplots\\n\",\n",
    "    \"- Valores atípicos visuales\"\n",
    "   ]\n",

    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"os.chdir('/content')\\n\",\n",
    "    \"url = \\\"https://github.com/TU-USUARIO/endes-anemia2024.git\\\"\\n\",\n",
    "    \"!git clone {url}\\n\",\n",
    "    \"print(\\\"✓ Repositorio clonado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Cargar datos\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Configuración\\n\",\n",
    "    \"sns.set_style('whitegrid')\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (12, 6)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copiar datos\\n\",\n",
    "    \"DRIVE = Path('/content/drive/My Drive/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB = Path('/content/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in DRIVE.glob('*.csv'):\\n\",\n",
    "    \"    shutil.copy(file, COLAB / file.name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cargar datos escalados (Fase 5)\\n\",\n",
    "    \"df = pd.read_csv(COLAB / '05_data_scaled.csv')\\n\",\n",
    "    \"print(f\\\"✓ Datos: {df.shape}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Estadísticas Descriptivas\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n=== ESTADÍSTICAS DESCRIPTIVAS ===\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nDataset: {df.shape[0]:,} registros × {df.shape[1]} columnas\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nMissing values:\\\")\\n\",\n",
    "    \"print(df.isnull().sum())\\n\",\n",
    "    \"print(f\\\"\\\\nTipos de datos:\\\")\\n\",\n",
    "    \"print(df.dtypes)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n=== VARIABLE RESPUESTA: anemia_nivel ===\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nDistribución:\\\")\\n\",\n",
    "    \"print(df['anemia_nivel'].value_counts().sort_index())\\n\",\n",
    "    \"print(f\\\"\\\\nPorcentajes:\\\")\\n\",\n",
    "    \"print(df['anemia_nivel'].value_counts(normalize=True).sort_index() * 100)\\n\",\n",
    "    \"print(f\\\"\\\\nEstadísticas:\\\")\\n\",\n",
    "    \"print(df['anemia_nivel'].describe())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Análisis por Variable Continua\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n=== VARIABLES CONTINUAS ===\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"continuas = ['edad_nino', 'edad_madre']\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in continuas:\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        print(f\\\"\\\\n{var.upper()}:\\\")\\n\",\n",
    "    \"        print(df[var].describe())\\n\",\n",
    "    \"        print(f\\\"  Skewness: {df[var].skew():.4f}\\\")\\n\",\n",
    "    \"        print(f\\\"  Kurtosis: {df[var].kurtosis():.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Visualización: Distribuciones Continuas\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(2, 2, figsize=(14, 10))\\n\",\n",
    "    \"\\n\",\n",
    "    \"for idx, var in enumerate(continuas):\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        # Histograma\\n\",\n",
    "    \"        ax = axes[idx, 0]\\n\",\n",
    "    \"        ax.hist(df[var], bins=30, alpha=0.7, color='skyblue', edgecolor='black')\\n\",\n",
    "    \"        ax.set_xlabel(var, fontsize=11, fontweight='bold')\\n\",\n",
    "    \"        ax.set_ylabel('Frecuencia', fontsize=11, fontweight='bold')\\n\",\n",
    "    \"        ax.set_title(f'Distribución: {var}', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"        ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Boxplot\\n\",\n",
    "    \"        ax = axes[idx, 1]\\n\",\n",
    "    \"        ax.boxplot(df[var], vert=True)\\n\",\n",
    "    \"        ax.set_ylabel(var, fontsize=11, fontweight='bold')\\n\",\n",
    "    \"        ax.set_title(f'Boxplot: {var}', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"        ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/07_distribuciones_continuas.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Análisis por Variable Categórica\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n=== VARIABLES CATEGÓRICAS ===\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"categoricas = ['quintil_raw_3', 'quintil_raw_4', 'quintil_raw_5', 'edu_madre_3.0', 'sexo_nino_code_2']\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in categoricas:\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        print(f\\\"\\\\n{var.upper()}:\\\")\\n\",\n",
    "    \"        counts = df[var].value_counts()\\n\",\n",
    "    \"        print(counts)\\n\",\n",
    "    \"        print(f\\\"  Porcentajes:\\\")\\n\",\n",
    "    \"        print(df[var].value_counts(normalize=True) * 100)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Visualización: Variables Categóricas\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(2, 3, figsize=(15, 10))\\n\",\n",
    "    \"axes = axes.flatten()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for idx, var in enumerate(categoricas):\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        ax = axes[idx]\\n\",\n",
    "    \"        counts = df[var].value_counts()\\n\",\n",
    "    \"        ax.bar(counts.index, counts.values, alpha=0.7, color='skyblue', edgecolor='black')\\n\",\n",
    "    \"        ax.set_xlabel(var, fontsize=11, fontweight='bold')\\n\",\n",
    "    \"        ax.set_ylabel('Frecuencia', fontsize=11, fontweight='bold')\\n\",\n",
    "    \"        ax.set_title(f'Distribución: {var}', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"        ax.grid(True, alpha=0.3, axis='y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Remover último subplot vacío\\n\",\n",
    "    \"fig.delaxes(axes[-1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/07_distribuciones_categoricas.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. Visualización: Variable Respuesta\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Barplot\\n\",\n",
    "    \"ax = axes[0]\\n\",\n",
    "    \"counts = df['anemia_nivel'].value_counts().sort_index()\\n\",\n",
    "    \"ax.bar(counts.index, counts.values, alpha=0.7, color=['#d62728', '#ff7f0e', '#2ca02c', '#1f77b4'], edgecolor='black')\\n\",\n",
    "    \"ax.set_xlabel('Nivel de Anemia', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_ylabel('Frecuencia', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title('Distribución: anemia_nivel', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"ax.set_xticks([1, 2, 3, 4])\\n\",\n",
    "    \"ax.set_xticklabels(['Grave', 'Moderada', 'Leve', 'Sin Anemia'])\\n\",\n",
    "    \"ax.grid(True, alpha=0.3, axis='y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Pie chart\\n\",\n",
    "    \"ax = axes[1]\\n\",\n",
    "    \"sizes = df['anemia_nivel'].value_counts().sort_index().values\\n\",\n",
    "    \"labels = ['Grave', 'Moderada', 'Leve', 'Sin Anemia']\\n\",\n",
    "    \"colors = ['#d62728', '#ff7f0e', '#2ca02c', '#1f77b4']\\n\",\n",
    "    \"ax.pie(sizes, labels=labels, colors=colors, autopct='%1.1f%%', startangle=90)\\n\",\n",
    "    \"ax.set_title('Proporción: anemia_nivel', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/07_variable_respuesta.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. Correlación con Variable Respuesta\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from scipy.stats import spearmanr\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n=== CORRELACIÓN CON VARIABLE RESPUESTA ===\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nVariables continuas:\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var in continuas:\\n\",\n",
    "    \"    if var in df.columns:\\n\",\n",
    "    \"        corr, pval = spearmanr(df[var], df['anemia_nivel'])\\n\",\n",
    "    \"        sig = \\\"***\\\" if pval < 0.001 else \\\"**\\\" if pval < 0.01 else \\\"*\\\" if pval < 0.05 else \\\"ns\\\"\\n\",\n",
    "    \"        print(f\\\"  {var:20s} | r={corr:7.4f} | p={pval:.6f} {sig}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 10. Resumen y Guardar\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESULTS = Path('/content/endes-anemia2024/results')\\n\",\n",
    "    \"RESULTS.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"output = RESULTS / \\\"07_univariate_analysis.txt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(output, 'w') as f:\\n\",\n",
    "    \"    f.write(\\\"FASE 7: ANÁLISIS UNIVARIADO\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"=\\\"*60 + \\\"\\\\n\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"Dataset: {df.shape[0]:,} registros × {df.shape[1]} columnas\\\\n\\\\n\\\")\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    f.write(\\\"VARIABLE RESPUESTA (anemia_nivel):\\\\n\\\")\\n\",\n",
    "    \"    f.write(str(df['anemia_nivel'].value_counts().sort_index()))\\n\",\n",
    "    \"    f.write(f\\\"\\\\n\\\\nESTADÍSTICAS DESCRIPTIVAS:\\\\n\\\")\\n\",\n",
    "    \"    f.write(str(df.describe()))\\n\",\n",
    "    \"    f.write(f\\\"\\\\n\\\\nCONCLUSIONES:\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"- Distribución anemia: {len(df[df['anemia_nivel']==1])} grave, \\\"\\n\",\n",
    "    \"            f\\\"{len(df[df['anemia_nivel']==2])} moderada, \\\"\\n\",\n",
    "    \"            f\\\"{len(df[df['anemia_nivel']==3])} leve, \\\"\\n\",\n",
    "    \"            f\\\"{len(df[df['anemia_nivel']==4])} sin anemia\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"- Variables continuas escaladas (Z-score)\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"- Sin valores faltantes en variables clave\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Resultados guardados: {output}\\\")\"\n",
    "   ]\n",
    "  },\n",

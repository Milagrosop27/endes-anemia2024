    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# FASE 9: Análisis Multivariado - Regresión Ordinal Logit\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Objetivo:** Modelo que explique anemia controlando por confundidores\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Modelo:** Regresión Ordinal Logit (7 variables optimizadas)\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Interpretación:** Coeficientes = Log-odds de transitar a categorías más severas de anemia\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from google.colab import drive\\n\",\n",
    "    \"drive.mount('/content/drive')\\n\",\n",
    "    \"!pip install -q pandas numpy scipy scikit-learn statsmodels matplotlib seaborn\\n\",\n",
    "    \"print(\\\"✓ Setup completado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"os.chdir('/content')\\n\",\n",
    "    \"url = \\\"https://github.com/TU-USUARIO/endes-anemia2024.git\\\"\\n\",\n",
    "    \"!git clone {url}\\n\",\n",
    "    \"print(\\\"✓ Repositorio clonado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Cargar datos y preparar\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copiar datos\\n\",\n",
    "    \"DRIVE = Path('/content/drive/My Drive/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB = Path('/content/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in DRIVE.glob('*.csv'):\\n\",\n",
    "    \"    shutil.copy(file, COLAB / file.name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cargar\\n\",\n",
    "    \"df = pd.read_csv(COLAB / '06_data_features_selected.csv')\\n\",\n",
    "    \"print(f\\\"✓ Datos: {df.shape}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Preparar modelo (7 variables - Opción A)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from scipy.stats import spearmanr, chi2_contingency\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Variables respuesta\\n\",\n",
    "    \"y = df['anemia_nivel']\\n\",\n",
    "    \"X_full = df.drop(['HHID', 'anemia_nivel'], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Variables a remover (6)\\n\",\n",
    "    \"vars_remove = [\\n\",\n",
    "    \"    'ponderador_raw',\\n\",\n",
    "    \"    'indice_riqueza',\\n\",\n",
    "    \"    'estrato',\\n\",\n",
    "    \"    'quintil_raw_2',\\n\",\n",
    "    \"    'edu_madre_1.0',\\n\",\n",
    "    \"    'HC60'\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_reduced = X_full.drop([col for col in vars_remove if col in X_full.columns], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Limpiar NaN\\n\",\n",
    "    \"mask = y.notna() & X_reduced.notna().all(axis=1)\\n\",\n",
    "    \"y_clean = y[mask]\\n\",\n",
    "    \"X_clean = X_reduced[mask]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Variables finales (7): {list(X_clean.columns)}\\\")\\n\",\n",
    "    \"print(f\\\"✓ Registros: {len(y_clean):,}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Ajustar modelo ordinal logit\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from statsmodels.miscmodels.ordinal_model import OrderedModel\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ajustar modelo\\n\",\n",
    "    \"model = OrderedModel(y_clean, X_clean, distr='logit')\\n\",\n",
    "    \"result = model.fit(disp=False, maxiter=500, gtol=1e-5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n=== MODELO AJUSTADO ===\\\")\\n\",\n",
    "    \"print(f\\\"Convergencia: ✓ EXITOSA\\\" if result.mle_retvals.get('converged') else \\\"✗ ADVERTENCIA\\\")\\n\",\n",
    "    \"print(f\\\"Log-Likelihood: {result.llf:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"AIC: {result.aic:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"BIC: {result.bic:.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Coeficientes significativos\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"\\\\n=== COEFICIENTES SIGNIFICATIVOS (p < 0.05) ===\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"params = result.params\\n\",\n",
    "    \"pvalues = result.pvalues\\n\",\n",
    "    \"\\n\",\n",
    "    \"for var, coef in params.items():\\n\",\n",
    "    \"    if 'gamma' not in var and 'Alpha' not in var:\\n\",\n",
    "    \"        pval = pvalues[var]\\n\",\n",
    "    \"        sig = '***' if pval < 0.001 else '**' if pval < 0.01 else '*' if pval < 0.05 else 'ns'\\n\",\n",
    "    \"        if pval < 0.05:\\n\",\n",
    "    \"            direction = \\\"↑ aumenta\\\" if coef > 0 else \\\"↓ disminuye\\\"\\n\",\n",
    "    \"            print(f\\\"\\\\n{var}\\\")\\n\",\n",
    "    \"            print(f\\\"  Coef: {coef:.6f} {sig}\\\")\\n\",\n",
    "    \"            print(f\\\"  p-value: {pval:.6f}\\\")\\n\",\n",
    "    \"            print(f\\\"  Interpretación: Log-odds {direction}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Resumen completo del modelo\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(result.summary())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Visualización: Coeficientes\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Preparar datos para gráfico\\n\",\n",
    "    \"coef_data = []\\n\",\n",
    "    \"for var, coef in params.items():\\n\",\n",
    "    \"    if 'gamma' not in var and 'Alpha' not in var:\\n\",\n",
    "    \"        coef_data.append({'Variable': var, 'Coeficiente': coef, 'P-value': pvalues[var]})\\n\",\n",
    "    \"\\n\",\n",
    "    \"coef_df = pd.DataFrame(coef_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Gráfico\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 6))\\n\",\n",
    "    \"colors = ['green' if c > 0 else 'red' for c in coef_df['Coeficiente']]\\n\",\n",
    "    \"ax.barh(coef_df['Variable'], coef_df['Coeficiente'], color=colors, alpha=0.7, edgecolor='black')\\n\",\n",
    "    \"ax.set_xlabel('Coeficiente (Log-odds)', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title('Regresión Ordinal Logit - Coeficientes Estimados', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"ax.axvline(x=0, color='black', linestyle='-', linewidth=1)\\n\",\n",
    "    \"ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/09_coeficientes.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. Guardar resultados\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"RESULTS = Path('/content/endes-anemia2024/results')\\n\",\n",
    "    \"RESULTS.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"output = RESULTS / \\\"09_ordinal_regression_results.txt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(output, 'w') as f:\\n\",\n",
    "    \"    f.write(\\\"FASE 9: REGRESIÓN ORDINAL LOGIT\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"=\\\"*60 + \\\"\\\\n\\\\n\\\")\\n\",\n",
    "    \"    f.write(str(result.summary()))\\n\",\n",
    "    \"    f.write(\\\"\\\\n\\\\n\\\" + \\\"=\\\"*60 + \\\"\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"INTERPRETACIÓN:\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"- 7 variables optimizadas para convergencia\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"- Coeficientes = Log-odds\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"- Positivo: aumenta probabilidad de anemia severa\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"- Negativo: disminuye probabilidad\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Resultados guardados: {output}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. Actualizar GitHub\"\n",
    "   ]\n",

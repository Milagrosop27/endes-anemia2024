   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# FASE 10: Clustering + PCA\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Objetivo:** Segmentar hogares y reducir dimensionalidad\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Métodos:**\\n\",\n",
    "    \"- PCA: Reducción de dimensionalidad\\n\",\n",
    "    \"- Método del Codo: Determinar k óptimo\\n\",\n",
    "    \"- K-means: Clustering\\n\",\n",
    "    \"- Silhouette: Validación de clusters\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from google.colab import drive\\n\",\n",
    "    \"drive.mount('/content/drive')\\n\",\n",
    "    \"!pip install -q pandas numpy scipy scikit-learn statsmodels matplotlib seaborn\\n\",\n",
    "    \"print(\\\"✓ Setup completado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"os.chdir('/content')\\n\",\n",
    "    \"url = \\\"https://github.com/TU-USUARIO/endes-anemia2024.git\\\"\\n\",\n",
    "    \"!git clone {url}\\n\",\n",
    "    \"print(\\\"✓ Repositorio clonado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Cargar datos\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copiar datos\\n\",\n",
    "    \"DRIVE = Path('/content/drive/My Drive/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB = Path('/content/endes-anemia2024/data')\\n\",\n",
    "    \"COLAB.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in DRIVE.glob('*.csv'):\\n\",\n",
    "    \"    shutil.copy(file, COLAB / file.name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cargar datos escalados\\n\",\n",
    "    \"df = pd.read_csv(COLAB / '05_data_scaled.csv')\\n\",\n",
    "    \"print(f\\\"✓ Datos escalados: {df.shape}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. PCA\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from sklearn.decomposition import PCA\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Variables predictoras (excluir HHID y respuesta)\\n\",\n",
    "    \"cols_exclude = ['HHID', 'anemia_nivel'] if 'anemia_nivel' in df.columns else ['HHID']\\n\",\n",
    "    \"X = df.drop(cols_exclude, axis=1, errors='ignore')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# PCA\\n\",\n",
    "    \"pca = PCA()\\n\",\n",
    "    \"X_pca = pca.fit_transform(X)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n=== PCA ===\\\")\\n\",\n",
    "    \"print(f\\\"Varianza explicada acumulada:\\\")\\n\",\n",
    "    \"cumvar = np.cumsum(pca.explained_variance_ratio_)\\n\",\n",
    "    \"for i in [2, 3, 4, 5]:\\n\",\n",
    "    \"    if i <= len(cumvar):\\n\",\n",
    "    \"        print(f\\\"  {i} componentes: {cumvar[i-1]:.2%}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Método del Codo\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from sklearn.cluster import KMeans\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Usar PCA con 2 componentes para visualización\\n\",\n",
    "    \"pca2 = PCA(n_components=2)\\n\",\n",
    "    \"X_pca2 = pca2.fit_transform(X)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Método del codo\\n\",\n",
    "    \"inertias = []\\n\",\n",
    "    \"ks = range(2, 11)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for k in ks:\\n\",\n",
    "    \"    km = KMeans(n_clusters=k, random_state=42, n_init=10)\\n\",\n",
    "    \"    km.fit(X_pca2)\\n\",\n",
    "    \"    inertias.append(km.inertia_)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Gráfico\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 6))\\n\",\n",
    "    \"ax.plot(ks, inertias, 'bo-', linewidth=2, markersize=8)\\n\",\n",
    "    \"ax.set_xlabel('Número de Clusters (k)', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_ylabel('Inercia', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title('Método del Codo - K-means', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/10_elbow_curve.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico del codo guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. K-means (k=3)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Usar k=3 (recomendado por codo)\\n\",\n",
    "    \"k_optimal = 3\\n\",\n",
    "    \"kmeans = KMeans(n_clusters=k_optimal, random_state=42, n_init=10)\\n\",\n",
    "    \"clusters = kmeans.fit_predict(X_pca2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n=== K-MEANS (k={k_optimal}) ===\\\")\\n\",\n",
    "    \"unique, counts = np.unique(clusters, return_counts=True)\\n\",\n",
    "    \"for cluster, count in zip(unique, counts):\\n\",\n",
    "    \"    print(f\\\"Cluster {cluster}: {count} observaciones ({count/len(clusters)*100:.1f}%)\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Visualización: Clusters en PCA\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 8))\\n\",\n",
    "    \"\\n\",\n",
    "    \"scatter = ax.scatter(X_pca2[:, 0], X_pca2[:, 1], c=clusters, cmap='viridis', \\n\",\n",
    "    \"                     alpha=0.6, s=50, edgecolors='black', linewidth=0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Centros\\n\",\n",
    "    \"centers_pca = kmeans.cluster_centers_\\n\",\n",
    "    \"ax.scatter(centers_pca[:, 0], centers_pca[:, 1], c='red', marker='X', \\n\",\n",
    "    \"          s=300, edgecolors='black', linewidth=2, label='Centroides')\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_xlabel(f'PC1 ({pca2.explained_variance_ratio_[0]:.1%})', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_ylabel(f'PC2 ({pca2.explained_variance_ratio_[1]:.1%})', fontsize=12, fontweight='bold')\\n\",\n",
    "    \"ax.set_title(f'K-means Clustering (k={k_optimal}) en PCA', fontsize=14, fontweight='bold')\\n\",\n",
    "    \"cbar = plt.colorbar(scatter, ax=ax)\\n\",\n",
    "    \"cbar.set_label('Cluster', fontweight='bold')\\n\",\n",
    "    \"ax.legend()\\n\",\n",
    "    \"ax.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('/content/endes-anemia2024/results/10_clusters_pca.png', dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ Gráfico de clusters guardado\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Validación: Silhouette Score\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from sklearn.metrics import silhouette_score, silhouette_samples\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Silhouette score\\n\",\n",
    "    \"sil_score = silhouette_score(X_pca2, clusters)\\n\",\n",
    "    \"print(f\\\"\\\\n=== VALIDACIÓN ===\\\")\\n\",\n",
    "    \"print(f\\\"Silhouette Score: {sil_score:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Interpretación: {'Buena' if sil_score > 0.5 else 'Moderada' if sil_score > 0.3 else 'Débil'} cohesión de clusters\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. Guardar resultados\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESULTS = Path('/content/endes-anemia2024/results')\\n\",\n",
    "    \"RESULTS.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"output = RESULTS / \\\"10_clustering_pca_results.txt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(output, 'w') as f:\\n\",\n",
    "    \"    f.write(\\\"FASE 10: CLUSTERING + PCA\\\\n\\\")\\n\",\n",
    "    \"    f.write(\\\"=\\\"*60 + \\\"\\\\n\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"PCA: {pca2.explained_variance_ratio_[0]:.1%} + {pca2.explained_variance_ratio_[1]:.1%} = \\\"\\n\",\n",
    "    \"            f\\\"{sum(pca2.explained_variance_ratio_):.1%}\\\\n\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"K-means (k={k_optimal}):\\\\n\\\")\\n\",\n",
    "    \"    for cluster, count in zip(unique, counts):\\n\",\n",
    "    \"        f.write(f\\\"  Cluster {cluster}: {count} obs ({count/len(clusters)*100:.1f}%)\\\\n\\\")\\n\",\n",
    "    \"    f.write(f\\\"\\\\nSilhouette Score: {sil_score:.4f}\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✓ Resultados guardados: {output}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. Actualizar GitHub\"\n",
    "   ]\n",
